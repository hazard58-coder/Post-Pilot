# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ─── Supabase (required) ──────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Supabase DB (required for /api/setup migration runner only) ──
# Find in: Supabase Dashboard → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# ─── AI Assistant (server-side only, never in bundle) ─────────
# Find in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Security ─────────────────────────────────────────────────
# Comma-separated list of allowed origins for the AI endpoint
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── First-access (optional, remove after real account created) ──
# Set this to unlock a temporary owner login on the auth screen.
# Delete it from Vercel once you've signed up with your real account.
VITE_OWNER_PASS=

# ─── One-time setup endpoint protection ───────────────────────
# Set any random string. Use it once at /api/setup?secret=THIS_VALUE
# Delete after setup is complete.
SETUP_SECRET=

# ─── Feature flags ────────────────────────────────────────────
VITE_DEMO_ENABLED=true
