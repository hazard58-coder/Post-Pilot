# ─── Supabase ─────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Admin Account ────────────────────────────────────────────
# Credentials for the built-in admin panel (not a Supabase user).
# Must be changed before deploying. Never commit actual values.
VITE_ADMIN_USERNAME=change-me
VITE_ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── Feature Flags ────────────────────────────────────────────
# Set to false to hide the "Try Demo Mode" button in production.
# Default is true (demo mode visible).
VITE_DEMO_ENABLED=true
