# ─── Supabase ─────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Admin Account ────────────────────────────────────────────
# Credentials for the built-in admin panel (not a Supabase user).
# Must be changed before deploying. Never commit actual values.
VITE_ADMIN_USERNAME=change-me
VITE_ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── AI Assistant ─────────────────────────────────────────────
# Server-side only — never expose this in the frontend bundle.
# The /api/generate serverless function reads this at request time.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Feature Flags ────────────────────────────────────────────
# Set to false to hide the "Try Demo Mode" button in production.
# Default is true (demo mode visible).
VITE_DEMO_ENABLED=true
